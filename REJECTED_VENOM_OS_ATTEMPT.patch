+  z-index: 9500;
+  width: min(22rem, calc(100vw - 2rem));
+  aspect-ratio: 16 / 9;
+  overflow: hidden;
+  border: 1px solid rgba(104, 255, 126, 0.42);
+  border-radius: 8px;
+  background: #050505;
+  box-shadow: 0 24px 80px rgba(0, 0, 0, 0.72), 0 0 42px rgba(54, 247, 107, 0.12);
+}
+
+.vo-floating-vsl iframe {
+  width: 100%;
+  height: 100%;
+  border: 0;
+  display: block;
+}
+
+.vo-floating-vsl__close {
+  position: absolute;
+  top: 0.5rem;
+  right: 0.5rem;
+  z-index: 2;
+  display: grid;
+  width: 2rem;
+  height: 2rem;
+  place-items: center;
+  border: 1px solid rgba(255, 255, 255, 0.18);
+  border-radius: 999px;
+  background: rgba(0, 0, 0, 0.72);
+  color: var(--vo-text);
+  backdrop-filter: blur(10px);
+}
+
+.mobile-command-bar {
+  border-top: 1px solid rgba(104, 255, 126, 0.24) !important;
+  background:
+    linear-gradient(90deg, rgba(104, 255, 126, 0.11), transparent 42%, rgba(255, 255, 255, 0.055)),
+    rgba(5, 7, 6, 0.92) !important;
+  padding-bottom: env(safe-area-inset-bottom);
+  backdrop-filter: blur(18px) saturate(150%) !important;
+}
+
+.mobile-command-bar > div {
+  padding: 0.7rem 1rem 0.6rem !important;
+  gap: 0.38rem !important;
+}
+
+.mobile-command-bar .btn-primary {
+  width: min(100%, 24rem);
+  min-height: 3.05rem !important;
+  border-radius: 999px !important;
+  flex-direction: row !important;
+  gap: 0.75rem !important;
+  background: var(--vo-green) !important;
+  color: #041006 !important;
+  border-color: var(--vo-green) !important;
+  padding: 0.76rem 1rem !important;
+}
+
+.mobile-command-bar .btn-primary span {
+  color: inherit !important;
+}
+
+.mobile-command-bar .btn-primary__glyph {
+  width: 1.9rem;
+  height: 1.9rem;
+  background: rgba(4, 16, 6, 0.92) !important;
+  color: var(--vo-green) !important;
+}
+
+.mobile-command-bar p {
+  color: var(--vo-muted) !important;
+  font-family: var(--font-mono-editorial), ui-monospace, monospace !important;
+  font-size: 0.65rem !important;
+  line-height: 1 !important;
+}
+
+@supports (animation-timeline: view()) {
+  @media (prefers-reduced-motion: no-preference) {
+    .venom-os .vo-section > .vo-container {
+      animation: vo-section-reveal both linear;
+      animation-timeline: view();
+      animation-range: entry 0% cover 24%;
+    }
+  }
+}
+
+@keyframes vo-section-reveal {
+  from {
+    opacity: 0.72;
+    transform: translateY(34px);
+    filter: blur(10px);
+  }
+  to {
+    opacity: 1;
+    transform: translateY(0);
+    filter: blur(0);
+  }
+}
+
+@media (prefers-reduced-motion: no-preference) {
+  .vo-doc-card--active {
+    animation: vo-active-doc 5.5s var(--vo-ease) infinite;
+  }
+}
+
+@keyframes vo-active-doc {
+  0%, 100% { box-shadow: 0 24px 70px rgba(0, 0, 0, 0.38), 0 0 0 rgba(104, 255, 126, 0); }
+  50% { box-shadow: 0 28px 84px rgba(0, 0, 0, 0.42), 0 0 38px rgba(104, 255, 126, 0.2); }
+}
+
+@media (min-width: 640px) {
+  .vo-container {
+    width: min(100% - 3rem, 1320px);
+  }
+  .vo-hero-title {
+    font-size: 3.12rem;
+  }
+  .vo-section h2 {
+    font-size: 4rem;
+  }
+  .vo-hero__meta {
+    grid-template-columns: repeat(3, minmax(0, 1fr));
+  }
+  .vo-problem-grid,
+  .vo-proof-grid,
+  .vo-faq__grid {
+    grid-template-columns: repeat(3, minmax(0, 1fr));
+  }
+  .vo-bento-grid {
+    grid-template-columns: repeat(2, minmax(0, 1fr));
+  }
+}
+
+@media (min-width: 1024px) {
+  .vo-section {
+    padding-block: 8rem;
+  }
+  .vo-hero {
+    padding-top: 5.2rem;
+    padding-bottom: 3rem;
+  }
+  .vo-hero__grid {
+    grid-template-columns: minmax(0, 1.05fr) minmax(26rem, 0.86fr);
+    gap: 4rem;
+  }
+  .vo-hero-title {
+    font-size: 3.8rem;
+  }
+  .vo-section h2 {
+    font-size: 5.35rem;
+  }
+  .vo-split {
+    grid-template-columns: minmax(0, 0.82fr) minmax(0, 1.18fr);
+    gap: 4rem;
+  }
+  .vo-founder__grid {
+    grid-template-columns: minmax(24rem, 0.75fr) minmax(0, 1fr);
+    gap: 4rem;
+  }
+  .vo-offer__grid {
+    grid-template-columns: minmax(0, 0.75fr) minmax(0, 1fr);
+    gap: 2rem;
+  }
+  .vo-bento-grid {
+    grid-template-columns: repeat(4, minmax(0, 1fr));
+  }
+  .vo-bento-card--wide {
+    grid-column: span 2;
+  }
+  .vo-founder__traits,
+  .vo-offer__cards {
+    grid-template-columns: repeat(2, minmax(0, 1fr));
+  }
+  .vo-final__content {
+    padding: 4rem;
+  }
+  .vo-floating-vsl {
+    right: 1.5rem;
+    bottom: 1.5rem;
+    width: 22rem;
+  }
+}
+
+@media (min-width: 1280px) {
+  .vo-hero-title {
+    font-size: 3.42rem;
+  }
+}
+
+@media (max-width: 767px) {
+  .vo-section {
+    padding-block: 4.6rem;
+  }
+  .vo-hero {
+    align-items: start;
+    padding-top: 6rem;
+  }
+  .vo-hero__actions,
+  .vo-hero__actions > span,
+  .vo-hero__actions .vo-cta {
+    width: 100%;
+  }
+  .vo-spatial-panel {
+    min-height: 0;
+  }
+  .vo-doc-stack {
+    min-height: 20rem;
+  }
+  .vo-doc-card {
+    transform: translate3d(0, calc(var(--vo-i) * 1.1rem), 0) scale(calc(1 - var(--vo-i) * 0.035));
+  }
+  .vo-founder__media,
+  .vo-final__panel {
+    min-height: 29rem;
+  }
+  .vo-final {
+    padding-bottom: calc(9rem + env(safe-area-inset-bottom));
+  }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  .venom-os *,
+  .venom-os *::before,
+  .venom-os *::after {
+    animation: none !important;
+    transition-duration: 1ms !important;
+    scroll-behavior: auto !important;
+  }
+  .vo-ambient {
+    display: none;
+  }
+}
+
 
